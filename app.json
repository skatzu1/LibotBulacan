{
  "expo": {
    "name": "Libot",
    "slug": "libot",
    "jsEngine": "hermes",
    "version": "1.0.0",
    "scheme": "libot",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "bundler": {
      "metro": {
        "assetExts": [
          "glb",
          "gltf",
          "bin",
          "tflite"
        ]
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "@reactvision/react-viro",
        {
          "android": {
            "xRMode": [
              "AR"
            ]
          },
          "ios": {
            "cameraUsagePermission": "Libot uses the camera for AR experiences.",
            "microphoneUsagePermission": "Libot uses your microphone for AR experiences.",
            "photosPermission": "Libot would like to read photos for AR.",
            "savephotosPermission": "Libot would like to save photos during AR."
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Libot needs your location to provide navigation to tourist spots in Bulacan.",
          "locationWhenInUsePermission": "Libot needs your location to show nearby tourist attractions.",
          "isIosBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Libot uses the camera to scan and verify products for missions.",
          "microphonePermission": false
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": true
        }
      ],
      "react-native-vision-camera"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skatzu15.libot",
      "infoPlist": {
        "NSCameraUsageDescription": "Libot uses the camera to show augmented reality tourism content and scan products for missions.",
        "NSLocationWhenInUseUsageDescription": "Libot needs your location to show nearby tourist spots and provide navigation.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Libot needs your location to show nearby tourist spots and provide navigation.",
        "NSPhotoLibraryUsageDescription": "Libot needs access to your photos for AR and mission scanning.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "libot"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "libot"
            ]
          }
        ],
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save photos",
        "NSMicrophoneUsageDescription": "Libot uses your microphone for AR experiences.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.skatzu15.libot.beta",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "libot"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ce019b8b-d9d3-49c7-be10-9f3624a80041"
      },
      "router": {}
    },
    "owner": "komiigurii"
  }
}
